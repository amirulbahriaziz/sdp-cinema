# Expo public env ‚Äî copy to `.env` for local dev (`.env` is gitignored).
# Base URL of the Laravel API (no trailing slash). Android emulator -> http://10.0.2.2:8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Data source toggle: `live` (HTTP -> Laravel) or `mock` (bundled mock/*.json).
# On a live failure the data layer falls back to `mock` so the app stays demoable offline.
EXPO_PUBLIC_DATA_SOURCE=live

# Reverb (WebSocket) for the live seat channel ‚Äî must match api/.env REVERB_*.
# Android emulator -> EXPO_PUBLIC_REVERB_HOST=10.0.2.2.
EXPO_PUBLIC_REVERB_KEY=snqbem6hvscwptd45osy
EXPO_PUBLIC_REVERB_HOST=127.0.0.1
EXPO_PUBLIC_REVERB_PORT=8080
EXPO_PUBLIC_REVERB_SCHEME=http

# Dev auto-login (live mode needs a Sanctum bearer token for lock/release/booking).
# For a 2-client FCFS demo, run the second simulator with a different user, e.g.
# EXPO_PUBLIC_DEMO_EMAIL=house@sdpcinema.test
EXPO_PUBLIC_DEMO_EMAIL=demo@sdpcinema.test
EXPO_PUBLIC_DEMO_PASSWORD=password
